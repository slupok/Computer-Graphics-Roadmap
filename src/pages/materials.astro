---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const allMaterials = await getCollection('materials');
const materials = allMaterials.sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title="Материалы — Computer Graphics Roadmap">
  <Header />

  <div id="materials" class="content">
    {materials.map((section) => (
      <div class="material">
        <div class="about-material">
          <h2>{section.data.title}</h2>
        </div>
        <div class="material-details">
          {section.data.resources.length > 0 && (
            <>
              <h3>Ресурсы</h3>
              <ul>
                {section.data.resources.map(r => (
                  <li>
                    <a href={r.url} target="_blank" rel="noopener">{r.title}</a>
                    {r.description && <>. {r.description}</>}
                  </li>
                ))}
              </ul>
            </>
          )}
          {section.data.articles.length > 0 && (
            <>
              <h3>Статьи</h3>
              <ul>
                {section.data.articles.map(r => (
                  <li>
                    <a href={r.url} target="_blank" rel="noopener">{r.title}</a>
                    {r.description && <>. {r.description}</>}
                  </li>
                ))}
              </ul>
            </>
          )}
        </div>
      </div>
    ))}
  </div>

  <Footer />
</BaseLayout>
