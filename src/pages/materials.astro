---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Материалы — Computer Graphics Roadmap">
  <Header />

  <div id="materials" class="content">
    <div id="common-material" class="material">
      <div class="about-material">
        <h2>Общее</h2>
      </div>
      <div class="material-details">
        <div class="sub-material">
          <h3>Ресурсы</h3>
          <ul>
            <li><a href="https://compscicenter.ru/">Computer Science Center</a>. Набор различных курсов по математике и программированию. В 2022 приостановил работу, но материалы там остались</li>
            <li><a href="https://habr.com/">Habr</a>. Главный IT-ресурс в СНГ</li>
            <li><a href="https://www.researchgate.net/">Research Gate</a>. Один из главных научных ресурсов в мире. </li>
            <li><a href="https://www.sci-hub.ru/">sci-hub</a>. Cвободный доступ ко всему научному знанию. Здесь можно найти 99.9% научных статей публикуемых в подписочных научных изданиях/журналах</li>
            <li><a href="https://teach-in.ru/about">Лекторий Teach-in</a>. Лекции учебных курсов МГУ</li>
            <li><a href="https://intuit.ru/studies/courses">НОУ ИНТУИТ</a>. Огромный набор различных курсов</li>
            <li><a href="https://csspace.io/">CS Space</a>. Свежий образовательный проект, имеются крутые лекции</li>
          </ul>
        </div>
      </div>
    </div>

    <div id="math-material" class="material">
      <div class="about-material">
        <h2>Математика</h2>
      </div>
      <div class="material-details">
        <div class="sub-material">
          <h3>Ресурсы</h3>
          <ul>
            <li><a href="http://mathprofi.ru/">mathprofi</a> – Высшая математика – просто и доступно</li>
            <li><a href="https://www.3blue1brown.com/">3BlueBrown</a>. Доступное объяснение математических концепций сопровождающиеся красивыми анимациями</li>
            <li><a href="https://www.manim.community/">manim</a>. Библиотека для создания математических анимаций. Та самая библиотека из роликов 3BlueBrown</li>
          </ul>
        </div>
        <div class="sub-material">
          <h3>Статьи</h3>
          <ul>
            <li><a href="https://nabbla1.livejournal.com/172771.html">Ликбез по кватернионам</a>. Самое подробное объяснение кватернионов</li>
          </ul>
        </div>
      </div>
    </div>

    <div id="cs-material" class="material">
      <div class="about-material">
        <h2>Программирование</h2>
      </div>
      <div class="material-details">
        <div class="sub-material">
          <h3>Ресурсы</h3>
          <ul>
            <li><a href="https://refactoring.guru/ru">Refactoring Guru</a>. Описание основных паттернов проектирования</li>
            <li><a href="https://gameprogrammingpatterns.com/">Паттерны проектирования в проектировании и программировании игр</a></li>
            <li><a href="https://salmer.github.io/CppDeveloperRoadmap/">C++ Developer Roadmap</a>. Дорожная карта развития C++ специалиста</li>
            <li><a href="https://isocpp.github.io/CppCoreGuidelines/CppCoreGuidelines">C++ Core Guidelines</a></li>
          </ul>
        </div>
        <div class="sub-material">
          <h3>Статьи</h3>
          <ul>
            <li><a href="https://habr.com/ru/articles/309796/">Оптимизация кода: процессор</a></li>
            <li><a href="https://habr.com/ru/articles/312078/">Оптимизация кода: память</a></li>
            <li><a href="https://habr.com/ru/articles/472052/">Data-Oriented Design</a></li>
            <li><a href="https://habr.com/ru/companies/ruvds/articles/850474/">Почему важно оптимизировать формат данных</a></li>
            <li><a href="https://habr.com/ru/articles/831754/">Обзор библиотек С++</a></li>
            <li><a href="https://habr.com/ru/articles/112953/">Машинная арифметика с плавающей точкой</a></li>
            <li><a href="https://habr.com/ru/companies/infopulse/articles/336110/">Быстрое вычисление обратного квадратного корня из Quake III Arena</a></li>
            <li><a href="https://habr.com/ru/articles/123143/">Некоторые советы по программированию</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div id="algorithms-and-data-structs-material" class="material">
      <div class="about-material">
        <h2>Алгоритмы и структуры данных</h2>
      </div>
      <div class="material-details">
        <div class="sub-material">
          <h3>Ресурсы</h3>
          <ul>
            <li><a href="https://www.cs.usfca.edu/~galles/visualization/about.html">Data Structure Visualizations</a>. Визуализация алгоритмов и структур данных</li>
            <li><a href="https://ru.algorithmica.org/">Алгоритмика</a>. Сайт про алгоритмы</li>
          </ul>
        </div>
        <div class="sub-material">
          <h3>Статьи</h3>
          <ul>
            <li><a href="https://habr.com/ru/companies/vk/articles/479822/">Статья про компактные структуры данных</a></li>
            <li><a href="https://habr.com/ru/articles/849654/">Сравнение B-деревьев с хэш-таблицами</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div id="cg-material" class="material">
      <div class="about-material">
        <h2>Компьютерная графика</h2>
      </div>
      <div class="material-details">
        <div class="sub-material">
          <h3>Ресурсы</h3>
          <ul>
            <li><a href="https://github.com/prographon/graphics-developer-roadmap">Graphics developer roadmap</a>. Сборник ресурсов по изучению компьютерной графики</li>
            <li><a href="https://www.scratchapixel.com/index.html">Scratchapixel</a>. Сборник обучающих материалов разных уровней по компьютерной графики.</li>
            <li><a href="https://gamedev.ru/">Gamedev</a>. Популярный СНГ ресурс на тему разработки игр</li>
            <li><a href="https://www.shadertoy.com/">Shadertoy</a>. Онлайн-сообщество и инструмент для создания шейдеров</li>
            <li><a href="https://thebookofshaders.com/">The book of shaders</a>. Руководство по написанию по шейдерам</li>
            <li><a href="https://iquilezles.org/">Inigo Quilez blog</a>. Блог с набором неплохих материалов</li>
            <li><a href="https://www.siggraph.org/">SIGGRAPH</a>. Организация, занимающаяся развитием компьютерной графики и интерактивных технологий. Ежегодно проводят конференции</li>
            <li><a href="https://www.songho.ca/index.html">songho</a>. Полезные заметки по КГ: OpenGL, математика, цифровая обработка сигналов и другое</li>
            <li><a href="https://developer.nvidia.com/gpugems/gpugems/contributors">GPU Gems Series</a></li>
            <li><a href="https://www.realtimerendering.com/raytracinggems/">Ray Tracing Gems Series</a></li>
            <li><a href="https://momentsingraphics.de/index.html">Блог Moments in Graphics</a>. Блог посвященный КГ, много рассказывается о ray trace, path trace, PBR и spectral rendering</li>
          </ul>
        </div>
        <div class="sub-material">
          <h3>Статьи</h3>
          <ul>
            <li><a href="https://gpuopen.com/learn/rdna-performance-guide/">Performance Guide DirectX & Vulkan</a>. Лучшие практики и рекомендации по DirectX и Vulkan. Все коротко и по делу</li>
            <li><a href="https://habr.com/ru/articles/811345/">Особенности отрисовки линий</a></li>
            <li><a href="https://graphics.pixar.com/library/index.html">Библиотека Pixar</a>. Библиотека научных публикаций от Pixar</li>
            <li><a href="https://www.jendrikillner.com/tags/weekly/">Graphics Programming weekly</a>. Публикация еженедельных статей по КГ</li>
            <li><a href="https://erkaman.github.io/posts/junior_graphics_programmer_interview.html">Common Interview Questions</a>. Перечень некоторых распространенных вопросов на собеседовании</li>
            <li><a href="https://renderdoc.org">RenderDoc</a>. Отладчик для Vulkan, Direct3D и OpenGL</li>
            <li><a href="https://developer.nvidia.com/nsight-graphics">NVIDIA Nsight Graphics</a>. Отладчик от NVidia для Direct3D, Vulkan, OpenGL, OpenVR, и Oculus SDK</li>
            <li><a href="https://habr.com/ru/articles/873016/?code=b1b888fe99d13f0b6d44615bd1cb8260&state=IspBSRjpncrFRCs6R4szV7ci&hl=ru">Game++</a>. Серия статей (Не проверено)</li>
          </ul>
        </div>
      </div>
    </div>
    <div id="dip-material"></div>
    <div id="gamedev-material"></div>
    <div id="ml-material"></div>
    <div id="gl-material"></div>

    <div id="other-material" class="material">
      <div class="about-material">
        <h2>Разное</h2>
      </div>
      <div class="material-details">
        <div class="sub-material">
          <h3>Ресурсы</h3>
          <ul>
            <li><a href="https://github.com/hukenovs/dsp-theory?tab=readme-ov-file">Digital signal processing</a>. Курс по цифровой обработке сигналов .</li>
          </ul>
        </div>
        <div class="sub-material">
          <h3>Статьи</h3>
          <ul>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <Footer />
</BaseLayout>
