---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const allSubjects = await getCollection('subjects');
const allStages = await getCollection('stages');
const stages = allStages.sort((a, b) => a.data.order - b.data.order);

function getStageSubjects(stageId: string) {
  return allSubjects
    .filter(s => s.data.stage === stageId)
    .sort((a, b) => a.data.order - b.data.order);
}

---
<BaseLayout title="Computer Graphics Roadmap">
  <Header />

  <div id="about-background">
    <div class="about-describe content">
      <div class="about-text">
        <h2>О компьютерной графике</h2>
        <p>
          Программирование компьютерной графики — это сложная и многогранная область, охватывающая множество специализаций: от разработки игр до создания интеллектуальных систем.
          <br /><br />
          <b>Computer Graphics Roadmap</b> — это путеводитель для тех, кто осваивает программирование компьютерной графики.
          Здесь собраны книги, лекции и курсы, отобранные и систематизированные в удобную дорожную карту развития.
        </p>
      </div>
      <div class="about-img">
        <img src="/resources/Euclid.png" alt="Euclid" />
      </div>
    </div>
  </div>

  <div class="content">
    <div id="levels">
      {stages.map(stage => (
        <div id={stage.data.stage_id} class="section">
          <div class="level-about">
            <div class="level-header">
              <p class="level-number">{stage.data.stage_name}</p>
              <h2>{stage.data.title}</h2>
            </div>
            <div class="level-describe">
              <p>{stage.data.description}</p>
            </div>
          </div>
          <div class="subjects-list">
            {getStageSubjects(stage.data.stage_id).map(subject => (
              <div class="subject">
                <img class="subject-image-preview" src={subject.data.image} alt={subject.data.title} />
                <h3>{subject.data.title}</h3>
                <p style="white-space: pre-line">{subject.data.description}</p>
                <button class="subject-info-btn" data-id={subject.data.id}>Подробнее</button>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>

  <dialog id="subject-modal" style="padding: 0">
    <div id="modal-subject-box" style="padding: 1rem">
      <button id="close-modal-btn">&#x2715;</button>
    </div>
  </dialog>

  <Footer />
</BaseLayout>

<script type="application/json" id="subjects-data" set:html={JSON.stringify(
  allSubjects.map(s => ({
    id: s.data.id,
    title: s.data.title,
    description: s.data.description,
    resources: s.data.resources,
  }))
)}></script>

<script>
  interface Resource {
    level?: string;
    language?: string;
    url?: string;
    title: string;
    description?: string;
  }
  interface SubjectData {
    id: number;
    title: string;
    description: string;
    resources: Resource[];
  }

  const subjectsData: SubjectData[] = JSON.parse(
    document.getElementById('subjects-data')!.textContent!
  );
  const subjectsMap = new Map(subjectsData.map(s => [s.id, s]));

  const modal = document.getElementById('subject-modal') as HTMLDialogElement;
  const modalBox = document.getElementById('modal-subject-box')!;
  const closeBtn = document.getElementById('close-modal-btn')!;

  closeBtn.addEventListener('click', () => {
    modal.close();
  });

  document.querySelectorAll('.subject-info-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const id = Number((e.target as HTMLElement).dataset.id);
      const subject = subjectsMap.get(id);
      if (!subject) return;

      const resourcesHtml = subject.resources.map(r => {
        const level = r.level ? `<span class="resource-level">[${r.level}]</span> ` : '';
        const lang = r.language ? `<span class="resource-language">[${r.language}]</span> ` : '';
        const title = r.url
          ? `<a href="${r.url}" target="_blank" rel="noopener">${r.title}</a>`
          : r.title;
        const desc = r.description ? `. ${r.description}` : '';
        return `<li>${level}${lang}${title}${desc}</li>`;
      }).join('');

      modalBox.innerHTML = '';
      modalBox.appendChild(closeBtn);
      modalBox.insertAdjacentHTML('beforeend', `
        <h3>${subject.title}</h3>
        <p class="subject-description-modal">${subject.description}</p>
        <h4>Материалы для изучения</h4>
        <ul class="subject-resources">${resourcesHtml}</ul>
      `);
      modal.showModal();
      e.stopPropagation();
    });
  });

  document.addEventListener('click', (e) => {
    if (modal.open && !modalBox.contains(e.target as Node)) {
      modal.close();
    }
  });
</script>
